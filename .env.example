NODE_ENV=development
APP_NAME=Restaurent SaaS
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
REALTIME_URL=http://localhost:4001
WAITER_URL=http://localhost:4173
KITCHEN_URL=http://localhost:4174
# Optional LAN/router address for QR demos.
# Set this to your current machine IP on the restaurant/router network.
ROUTER_IP=192.168.1.45
CUSTOMER_ORIGIN=http://192.168.1.45:3000
# Optional explicit browser URLs for router/LAN demos.
# Usually leave NEXT_PUBLIC_API_URL blank in the Next app. Browser calls use /api/v1 and Next proxies to API_URL.
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_ROUTER_IP=192.168.1.45
# NEXT_PUBLIC_CUSTOMER_ORIGIN=http://192.168.1.45:3000
# NEXT_PUBLIC_REALTIME_URL=http://192.168.1.45:4001
# VITE_API_URL=http://192.168.1.45:4000
# VITE_REALTIME_URL=http://192.168.1.45:4001
API_PORT=4000
REALTIME_PORT=4001
WEB_PORT=3000
WAITER_PORT=4173
KITCHEN_PORT=4174
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=restaurent_saas
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_GUEST_SECRET=replace-me-guest
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_GUEST_TTL=6h
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=restaurent
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LAUNCH=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
CORS_ORIGINS=http://localhost:3000,http://localhost:4173,http://localhost:4174,http://192.168.1.45:3000,http://192.168.1.45:4173,http://192.168.1.45:4174
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=200
SEED_ADMIN_EMAIL=platform@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SENTRY_DSN=
LOG_LEVEL=debug
